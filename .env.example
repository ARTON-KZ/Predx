# Paymento Payment Gateway (dashboard: https://app.paymento.io)
PAYMENTO_API_KEY=your_paymento_api_key_here
# Secret key used to sign IPN callbacks (Paymento dashboard -> Settings)
PAYMENTO_SECRET_KEY=your_paymento_secret_key_here

# Admin Dashboard
ADMIN_PASSWORD=choose_a_strong_password_here

# JWT Signing Secret (use a long random string)
JWT_SECRET=your_random_jwt_secret_here_at_least_32_chars

# Server Config
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Telegram
TELEGRAM_LINK=https://t.me/gerentelll
